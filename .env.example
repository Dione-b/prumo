# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://prumo:prumo@localhost:5432/prumo_db

# ── API Security ──────────────────────────────────────────────────────────
API_KEY=your_api_key_here

# ── Gemini (Cloud) ────────────────────────────────────────────────────────
GEMINI_API_KEY="AIzaSy..."
GEMINI_SYNTHESIS_MODEL="gemini-2.5-pro"
GEMINI_FLASH_MODEL="gemini-2.5-flash"
GEMINI_TEMPERATURE=0.2

# ── Gemini Embedding ─────────────────────────────────────────────────────
# GEMINI_EMBEDDING_MODEL=text-embedding-004
# GEMINI_EMBEDDING_DIM=768

# ── Gemini Caching ────────────────────────────────────────────────────────
# GEMINI_CACHE_TTL=3600
# GEMINI_EXPLICIT_CACHE_MIN_TOKENS=4096
# GEMINI_FLASH_DELAY_MS=60

# ── Sistema ───────────────────────────────────────────────────────────────
# PROMPT_STORAGE_BACKEND=database
# GRAPH_INVALID_THRESHOLD=0.3

# ── Paths ─────────────────────────────────────────────────────────────────
# OUTPUT_DIR=outputs
