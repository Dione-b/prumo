# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://prumo:prumo@localhost:5432/prumo_db

# ── API Security ──────────────────────────────────────────────────────────
API_KEY=your_api_key_here

# ── Gemini (Cloud) ────────────────────────────────────────────────────────
GEMINI_API_KEY="AIzaSy..."
GEMINI_SYNTHESIS_MODEL="gemini-2.5-pro"
GEMINI_EXTRACTION_MODEL="gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"
GEMINI_EMBEDDING_DIM=768
GEMINI_TEMPERATURE=0.2

# ── Stellar Chat ──────────────────────────────────────────────────────────
STELLAR_PROJECT_ID=your-project-uuid-here

# ── Sistema ───────────────────────────────────────────────────────────────
PROMPT_STORAGE_BACKEND=database

# ── Paths ─────────────────────────────────────────────────────────────────
OUTPUT_DIR=outputs
