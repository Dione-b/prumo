# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://prumo:prumo@localhost:5432/prumo_db

# ── API Security ──────────────────────────────────────────────────────────
API_KEY=your_api_key_here

# ── Gemini (Cloud) ────────────────────────────────────────────────────────
GEMINI_API_KEY="AIzaSy..."
GEMINI_SYNTHESIS_MODEL="gemini-2.5-pro"
GEMINI_FLASH_MODEL="gemini-2.5-flash"
GEMINI_TEMPERATURE=0.2

# ── Gemini Caching ────────────────────────────────────────────────────────
# GEMINI_CACHE_TTL=3600
# GEMINI_EXPLICIT_CACHE_MIN_TOKENS=4096
# GEMINI_FLASH_DELAY_MS=60

# ── Sistema ───────────────────────────────────────────────────────────────
# PROMPT_STORAGE_BACKEND=database
# GRAPH_INVALID_THRESHOLD=0.3

# ── Ollama (Local) ────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_BUSINESS_MODEL=llama3.2:3b
# OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
# OLLAMA_EMBEDDING_DIM=1024
# OLLAMA_WORKERS=2
# OLLAMA_MAX_CONCURRENT=1
# OLLAMA_KEEP_ALIVE=0
# OLLAMA_REQUEST_TIMEOUT=300

# ── Paths ─────────────────────────────────────────────────────────────────
# OUTPUT_DIR=outputs
